[init]
	defaultBranch = main

[user]
	email = ayato-p@panchromatic.org
	name = ayato-p

[core]
	pager = delta
	autocrlf = input

[interactive]
	diffFilter = delta --color-only

[delta]
    navigate = true    # use n and N to move between diff sections
    light = false      # set to true if you're in a terminal w/ a light background color (e.g. the default macOS terminal)

[merge]
    conflictstyle = diff3

[diff]
    colorMoved = default

[alias]
	co = checkout
	br = branch
	ci = commit
	st = status
	s = status -sb
	fp = pull --rebase --autostash